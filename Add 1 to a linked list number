# Definition for singly-linked list node (provided by platform)
class Node:
    def __init__(self, data):
        self.data = data
        self.next = None

class Solution:
    def addOne(self, head):
        # Helper function to reverse linked list
        def reverse(node):
            prev = None
            curr = node
            while curr:
                nxt = curr.next
                curr.next = prev
                prev = curr
                curr = nxt
            return prev
        
        # Step 1: Reverse the linked list
        head = reverse(head)
        
        # Step 2: Add 1 to the reversed list
        curr = head
        carry = 1
        
        while curr:
            curr.data += carry
            if curr.data >= 10:
                curr.data %= 10
                carry = 1
            else:
                carry = 0
            # If carry is 0, no need to continue
            if not curr.next and carry:
                curr.next = Node(0)
            curr = curr.next
        
        # Step 3: Reverse back the list
        head = reverse(head)
        return head
