from collections import defaultdict

class Solution:
    def topoSort(self, V, edges):
        # Build adjacency list
        graph = defaultdict(list)
        for u, v in edges:
            graph[u].append(v)
        
        visited = [False] * V
        stack = []
        
        def dfs(node):
            visited[node] = True
            for neighbor in graph[node]:
                if not visited[neighbor]:
                    dfs(neighbor)
            stack.append(node)  # append after visiting all neighbors
        
        # Perform DFS from all unvisited nodes
        for i in range(V):
            if not visited[i]:
                dfs(i)
        
        # Return topological order (reverse of finishing stack)
        return stack[::-1]
