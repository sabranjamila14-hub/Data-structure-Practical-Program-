class Solution:
    
    def isPossible(self, arr, k, limit):
        students = 1
        pages = 0
        
        for book in arr:
            if pages + book > limit:
                students += 1
                pages = book
                if students > k:
                    return False
            else:
                pages += book
                
        return True
    
    def findPages(self, arr, k):
        n = len(arr)
        
        if k > n:
            return -1
        
        low = max(arr)
        high = sum(arr)
        ans = -1
        
        while low <= high:
            mid = (low + high) // 2
            
            if self.isPossible(arr, k, mid):
                ans = mid
                high = mid - 1
            else:
                low = mid + 1
                
        return ans
