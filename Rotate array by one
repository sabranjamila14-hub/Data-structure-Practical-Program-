class Solution:
    def rotate(self, arr):
        n = len(arr)
        if n <= 1:
            return arr
        
        last = arr[-1]  # Save last element
        
        # Shift elements to the right
        for i in range(n-1, 0, -1):
            arr[i] = arr[i-1]
        
        arr[0] = last
        return arr
