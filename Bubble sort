class Solution:
    def bubbleSort(self, arr):
        n = len(arr)
        
        for i in range(n):
            # Track if any swap happened in this pass
            swapped = False
            
            # Last i elements are already sorted
            for j in range(0, n - i - 1):
                if arr[j] > arr[j + 1]:
                    arr[j], arr[j + 1] = arr[j + 1], arr[j]
                    swapped = True
            
            # If no swaps happened, array is already sorted
            if not swapped:
                break
        
        return arr
