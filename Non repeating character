class Solution:
    def nonRepeatingChar(self, s):
        # Step 1: Count frequency of each character
        freq = {}
        for ch in s:
            freq[ch] = freq.get(ch, 0) + 1
        
        # Step 2: Find first character with frequency 1
        for ch in s:
            if freq[ch] == 1:
                return ch
        
        # Step 3: If no non-repeating character found
        return '$'
