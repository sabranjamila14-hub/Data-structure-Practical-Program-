class Solution:
    def lengthOfLoop(self, head):
        slow = head
        fast = head

        # Detect loop
        while fast and fast.next:
            slow = slow.next
            fast = fast.next.next

            if slow == fast:   # Loop detected
                count = 1
                temp = slow.next

                while temp != slow:
                    count += 1
                    temp = temp.next

                return count

        return 0
