class Solution:
    def dfs(self, adj):
        V = len(adj)
        visited = [False] * V
        result = []

        def dfs_util(node):
            visited[node] = True
            result.append(node)

            for neighbor in adj[node]:
                if not visited[neighbor]:
                    dfs_util(neighbor)

        dfs_util(0)
        return result
